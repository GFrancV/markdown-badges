---
import SpeedInsights from "@vercel/speed-insights/astro";

import { getBaseJsonLd, getBreadcrumbJsonLd } from "@/lib/seo";

interface Props {
  title: string;
  description: string;
  image: string;
  keywords?: string;
  type?: "website" | "article";
  noIndex?: boolean;
  jsonLd?: Record<string, any>;
}

const { title, description, image, keywords, type, noIndex, jsonLd } =
  Astro.props;

const url = import.meta.env.SITE;
const pathSegments = Astro.url.pathname.split("/").filter(Boolean);

const canonicalUrl = new URL(Astro.url.pathname, url).toString();
const ogImage = image.startsWith("http")
  ? image
  : new URL(image, url ?? Astro.url).toString();
---

<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />

<!-- Favicon and App Icons -->
<link
  rel="icon"
  type="image/png"
  href="/favicon/favicon-96x96.png?v=20260512"
  sizes="96x96"
/>
<link
  rel="apple-touch-icon"
  sizes="180x180"
  href="/favicon/apple-touch-icon.png?v=20260512"
/>
<link rel="icon" type="image/svg+xml" href="/favicon.svg?v=20260512" />
<link rel="shortcut icon" href="/favicon.ico?v=20260512" />
<link rel="manifest" href="/site.webmanifest?v=20260512" />
<meta name="apple-mobile-web-app-title" content="Markdown Badges" />

<!-- SEO Meta Tags Basics -->
<title>{title}</title>
<meta name="description" content={description} />
<meta name="keywords" content={keywords} />
<meta name="author" content="GFrancV" />
<link rel="canonical" href={canonicalUrl} />
<link rel="sitemap" href="/sitemap-index.xml" />

<!-- Indexing -->
<meta name="robots" content={noIndex ? "noindex, nofollow" : "index, follow"} />
<meta
  name="googlebot"
  content={noIndex ? "noindex, nofollow" : "index, follow"}
/>
<meta
  name="bingbot"
  content={noIndex ? "noindex, nofollow" : "index, follow"}
/>

<!-- Theme Color -->
<meta name="theme-color" content="#121212" />
<meta name="color-scheme" content="dark light" />

<!-- Open Graph -->
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:image" content={ogImage} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content={title} />
<meta property="og:site_name" content="Markdown Badges" />
<meta property="og:type" content={type ?? "website"} />
<meta property="og:locale" content="en_US" />

<!-- Twitter Meta Tags -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:site" content="@GFrancV" />
<meta name="twitter:creator" content="@GFrancV" />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />
<meta property="twitter:url" content={canonicalUrl} />
<meta property="twitter:image" content={ogImage} />
<meta name="twitter:image:alt" content={title} />
<meta name="twitter:domain" content="markdown-badges.vercel.app" />

<!-- LinkedIn -->
<meta property="linkedin:owner" content="gabriel-chicaiza" />

<!-- Preloads -->
<link rel="preconnect" href="https://img.shields.io" />
<link rel="dns-prefetch" href="https://img.shields.io" />

<!-- JSON-LD Structured Data -->
<script
  is:inline
  type="application/ld+json"
  set:html={JSON.stringify(getBaseJsonLd())}
/>
<script
  is:inline
  type="application/ld+json"
  set:html={JSON.stringify(getBreadcrumbJsonLd(pathSegments))}
/>
{
  jsonLd && (
    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify(jsonLd)}
    />
  )
}

<!-- Analytics -->
<meta
  name="google-site-verification"
  content="bGA4Cm6PsD4Ug12ZPdf_xqLExFJaZDexlqZHsbL65SQ"
/>
<SpeedInsights />
