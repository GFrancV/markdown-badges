---
import "@/styles/global.css";

import { AppShell } from "@/components/app-shell";
import SEO from "@/components/SEO.astro";
import { Toaster } from "@/components/ui/sonner";
import { getCategoryBySlug } from "@/services/badges";

interface Props {
  title: string;
  description?: string;
  image?: string;
  keywords?: string;
  type?: "website" | "article";
  noIndex?: boolean;
  jsonLd?: Record<string, any>;
}

const {
  title,
  description = "Markdown badges generator for GitHub README. Browse 600+ badges for languages, frameworks, tools and platforms and copy ready-to-use Markdown instantly.",
  image = "/images/banners/og.png",
  keywords = "markdown badge, shield badges, readme badges, github profile badges, github badges, gfrancv",
  type = "website",
  noIndex = false,
  jsonLd,
} = Astro.props;

const pathname = Astro.url.pathname;

const categorySlug = pathname.startsWith("/categories/")
  ? pathname.slice("/categories/".length)
  : undefined;
const category = categorySlug ? getCategoryBySlug(categorySlug) : undefined;
---

<!doctype html>
<html lang="en">
  <head>
    <SEO
      title={title}
      description={description}
      image={image}
      keywords={keywords}
      type={type}
      noIndex={noIndex}
      jsonLd={jsonLd}
    />
  </head>
  <body>
    <AppShell client:load pathname={pathname} category={category}>
      <slot />
    </AppShell>
    <Toaster client:idle />
  </body>
</html>
